---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-content">
    <p>&copy; {currentYear} The Strategy Daddy. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .footer-content {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--spacing-lg);
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }
</style>
